---
import BadgeCard from './BadgeCard.astro';
import { cv, type Locale } from '../data/cv';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="certifications" class="section reveal">
  <h2 class="section-title">{t('certifications.title')}</h2>
  <p class="mt-3 text-muted">{t('certifications.subtitle')}</p>

  <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {cv.certifications.map((cert) => <BadgeCard cert={cert} locale={locale} />)}
  </div>
</section>
