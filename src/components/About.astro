---
import Icon from './Icon.astro';
import { cv, pick, type Locale } from '../data/cv';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="about" class="section reveal">
  <h2 class="section-title">{t('about.title')}</h2>

  <p class="mt-6 max-w-3xl text-lg leading-relaxed text-muted">
    {pick(cv.objective, locale)}
  </p>

  <div class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="surface rounded-2xl p-6">
      <div class="flex items-center gap-2 text-[rgb(var(--accent))]">
        <Icon name="graduation" class="h-5 w-5" />
        <h3 class="font-display text-sm font-bold uppercase tracking-wider">
          {t('about.education')}
        </h3>
      </div>
      <p class="mt-4 font-semibold">{pick(cv.education.degree, locale)}</p>
      <p class="mt-1 text-sm text-muted">{cv.education.institution}</p>
      <p class="mt-1 text-sm text-muted">{pick(cv.education.detail, locale)}</p>
    </div>

    <div class="surface rounded-2xl p-6">
      <div class="flex items-center gap-2 text-[rgb(var(--accent))]">
        <Icon name="languages" class="h-5 w-5" />
        <h3 class="font-display text-sm font-bold uppercase tracking-wider">
          {t('about.languages')}
        </h3>
      </div>
      <ul class="mt-4 space-y-2">
        {
          cv.languages.map((lang) => (
            <li class="flex items-baseline justify-between gap-4">
              <span class="font-medium">{pick(lang.name, locale)}</span>
              <span class="text-sm text-muted">{pick(lang.level, locale)}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
