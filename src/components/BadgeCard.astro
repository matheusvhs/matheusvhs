---
import Icon from './Icon.astro';
import { useTranslations } from '../i18n/ui';
import type { Certification, Locale } from '../data/cv';

interface Props {
  cert: Certification;
  locale: Locale;
}

const { cert, locale } = Astro.props;
const t = useTranslations(locale);

function formatValidUntil(value: string | null | undefined): string | null {
  if (value === undefined) return null; // desconhecido — não exibe o selo
  if (value === null) return t('certifications.permanent');
  const [year, month] = value.split('-').map(Number);
  const date = new Date(year, (month ?? 1) - 1);
  const formatted = new Intl.DateTimeFormat(locale === 'en' ? 'en-US' : 'pt-BR', {
    month: 'short',
    year: 'numeric',
  }).format(date);
  return `${t('certifications.validUntil')} ${formatted}`;
}

const validUntil = formatValidUntil(cert.validUntil);
---

<article
  class="surface group flex flex-col items-center rounded-2xl p-6 text-center transition hover:border-brand-400/60 hover:shadow-lg hover:shadow-brand-600/5"
>
  {
    cert.embedHtml ? (
      /* Embed oficial da plataforma (Accredible / Credly) */
      <div class="badge-embed w-full" set:html={cert.embedHtml} />
    ) : (
      /* Fallback: imagem do badge + link de verificação */
      <a
        href={cert.verifyUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-500"
        aria-label={`${cert.title} — ${t('certifications.verify')}`}
      >
        {cert.image ? (
          <img
            src={cert.image}
            alt={`${cert.title} — ${cert.issuer}`}
            width="140"
            height="140"
            loading="lazy"
            decoding="async"
            class="badge-img h-32 w-32 object-contain transition duration-300 group-hover:scale-105"
          />
        ) : (
          <span class="inline-flex h-32 w-32 items-center justify-center rounded-full bg-brand-500/10 text-[rgb(var(--accent))]">
            <Icon name="award" class="h-12 w-12" />
          </span>
        )}
      </a>
    )
  }

  <h3 class="mt-5 font-display text-base font-bold leading-snug">{cert.title}</h3>

  <p class="mt-1.5 text-sm text-muted">
    {cert.year ? `${cert.issuer} · ${cert.year}` : cert.issuer}
  </p>

  {
    validUntil && (
      <p class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-2.5 py-1 text-xs font-medium text-emerald-700 dark:text-emerald-400">
        <Icon name="check" class="h-3 w-3" />
        {validUntil}
      </p>
    )
  }

  <a
    href={cert.verifyUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[rgb(var(--accent))] transition hover:gap-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500"
  >
    {t('certifications.verify')}
    <Icon name="external" class="h-3.5 w-3.5" />
  </a>
</article>
