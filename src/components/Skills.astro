---
import Icon from './Icon.astro';
import { cv, pick, type Locale } from '../data/cv';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="skills" class="section reveal">
  <h2 class="section-title">{t('skills.title')}</h2>
  <p class="mt-3 text-muted">{t('skills.subtitle')}</p>

  <div class="mt-10 grid gap-4 sm:grid-cols-2">
    {
      cv.skills.map((skill) => (
        <div class="surface group rounded-2xl p-6 transition hover:border-brand-400/60">
          <div class="flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-brand-500/10 text-[rgb(var(--accent))] transition group-hover:bg-brand-500/20">
              <Icon name={skill.icon} class="h-5 w-5" />
            </span>
            <h3 class="font-display font-bold">{pick(skill.name, locale)}</h3>
          </div>
          <ul class="mt-4 flex flex-wrap gap-2">
            {skill.items.map((item) => (
              <li class="rounded-lg border border-[rgb(var(--border))] px-2.5 py-1 text-sm text-muted">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
